[Unit]
Description=OpenClaw Download Backend API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/openclaw-download-site/backend
ExecStart=/root/.openclaw/workspace/openclaw-download-site/backend/venv/bin/gunicorn -w 2 -b 127.0.0.1:5003 --access-logfile ../logs/backend-access.log --error-logfile ../logs/backend-error.log app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
